			$column = "tencongty,CASE WHEN Tendangnhap  IS NULL  THEN trn_congty.email ELSE Tendangnhap END Tendangnhap,trn_congty.hinhanh,diachicongty,DATE_FORMAT(trn_congty.DISORDER, '%d/%m/%Y %H:%i:%s') AS ngayposttin,user_id,trn_congty.email, ";
