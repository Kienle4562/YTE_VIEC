a:20:{s:14:"component_name";s:10:"Đăng ký";s:7:"warning";s:150:"Lưu ý: những thông tin được đánh dấu * là những thông tin cần thiết. Xin vui lòng nhập vào đầy đủ các thông tin này.";s:6:"broker";s:28:"Tên người giới thiệu";s:8:"fullname";s:13:"Họ và tên";s:8:"birthday";s:11:"Sinh nhật";s:5:"email";s:5:"Email";s:9:"telephone";s:15:"Điện thoại";s:7:"address";s:12:"Địa chỉ";s:17:"verification_code";s:15:"Mã xác nhận";s:12:"change_image";s:64:"[Tôi không đọc được, hãy đổi mã xác nhận khác]";s:12:"require_name";s:47:"Xin vui lòng nhập vào họ tên của bạn";s:13:"require_email";s:31:"Xin vui lòng nhập vào email";s:16:"require_birthday";s:39:"Vui lòng nhập ngày tháng năm sinh";s:15:"require_address";s:29:"Vui lòng nhập địa chỉ";s:17:"require_telephone";s:42:"Vui lòng nhập vào số điện thoại";s:15:"require_captcha";s:41:"Xin vui lòng nhập vào mã xác nhận";s:8:"btn_send";s:16:"Gửi thông tin";s:11:"msg_success";s:113:"Thông tin đăng ký đã được lưu lại. Chúng tôi sẽ xác nhận ID của bạn trong thời gian 24h";s:16:"msg_require_info";s:91:"Quý khách vui lòng cung cấp đầy đủ các thông tin cần thiết. Xin cảm ơn!";s:17:"msg_wrong_captcha";s:29:"Mã xác nhận không đúng";}